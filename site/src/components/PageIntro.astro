---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
}

const { eyebrow, summary, title } = Astro.props;
---

<section class="mx-auto grid w-full max-w-[1400px] gap-6 px-4 py-12 md:grid-cols-[minmax(0,1.8fr)_minmax(18rem,0.8fr)] md:px-8 md:py-20">
  <div class="space-y-5">
    <p class="eyebrow">{eyebrow}</p>
    <h1 class="page-title">{title}</h1>
    <p class="page-summary">{summary}</p>
  </div>
  <div class="intro-aside">
    <slot />
  </div>
</section>
