---
import { getCollection, render } from "astro:content";
import MarkdownEntry from "../../components/MarkdownEntry.astro";
import PageIntro from "../../components/PageIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const checklists = await getCollection("checklists");
const execution = checklists.find((entry) => entry.id === "execution");
const validation = checklists.find((entry) => entry.id === "validation");

if (!execution || !validation) {
  throw new Error("Required checklists not found.");
}

const executionRender = await render(execution);
const validationRender = await render(validation);

const checklistCards = [
  {
    id: "execution",
    title: "Execution Checklist",
    description: "Pre-flight checks before execution or release.",
  },
  {
    id: "validation",
    title: "Validation Checklist",
    description: "Sanity check whether milestone helped or only created more output.",
  },
];
---

<BaseLayout
  description="Operational checklists for execution and validation."
  title="Checklists | Grounded"
>
  <PageIntro
    eyebrow="Operational Discipline"
    summary="Checklists matter when complexity tries to re-enter through momentum, ambiguity, or excitement. Use them before and after a milestone."
    title="Short checks for shipping and reviewing."
  >
    <p class="text-sm leading-7 text-ink-soft">
      The point is not bureaucracy. The point is avoiding preventable drift.
    </p>
  </PageIntro>

  <section class="section-block">
    <div class="cl-grid">
      {checklistCards.map((card) => (
        <a class="cl-card" href={`#${card.id}`}>
          <div class="cl-card__indicator">
            <svg class="cl-card__circle" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="8.5" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="cl-card__content">
            <h3 class="cl-card__title">{card.title}</h3>
            <p class="cl-card__desc">{card.description}</p>
          </div>
          <span class="cl-card__link">
            View checklist
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <div id="execution">
    <MarkdownEntry content={executionRender.Content} />
  </div>
  <div id="validation">
    <MarkdownEntry content={validationRender.Content} />
  </div>
</BaseLayout>

<style>
  .cl-grid {
    display: grid;
    gap: 1.2rem;
  }

  .cl-card {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0 1rem;
    padding: 1.25rem 1.25rem 1rem;
    background: var(--color-surface);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition:
      transform var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .cl-card:hover {
    transform: translateY(-2px);
    background: var(--color-surface-raised);
  }

  .cl-card__indicator {
    grid-row: 1 / 3;
    display: flex;
    align-items: flex-start;
    padding-top: 0.15rem;
    color: var(--color-primary);
  }

  .cl-card__circle {
    display: block;
  }

  .cl-card__content {
    display: grid;
    gap: 0.35rem;
  }

  .cl-card__title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }

  .cl-card__desc {
    margin: 0;
    color: var(--color-ink-soft);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .cl-card__link {
    grid-column: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding-top: 0.5rem;
    color: var(--color-ink-muted);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .cl-card:hover .cl-card__link {
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .cl-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>